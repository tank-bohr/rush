

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 command: compound_command redirect_list
rule 19 command: function_definition
rule 20 redirect_list: io_redirect
rule 21 redirect_list: redirect_list io_redirect
rule 22 function_definition: WORD "(" ")" linebreak compound_command
rule 23 compound_command: brace_group
rule 24 compound_command: subshell
rule 25 compound_command: if_clause
rule 26 compound_command: while_clause
rule 27 compound_command: until_clause
rule 28 compound_command: for_clause
rule 29 compound_command: case_clause
rule 30 brace_group: Lbrace compound_list Rbrace
rule 31 subshell: "(" compound_list ")"
rule 32 while_clause: While compound_list do_group
rule 33 until_clause: Until compound_list do_group
rule 34 do_group: Do compound_list Done
rule 35 for_clause: For name do_group
rule 36 for_clause: For name sequential_sep do_group
rule 37 for_clause: For name linebreak In sequential_sep do_group
rule 38 for_clause: For name linebreak In wordlist sequential_sep do_group
rule 39 name: NAME
rule 40 wordlist: WORD
rule 41 wordlist: wordlist WORD
rule 42 sequential_sep: ";" linebreak
rule 43 sequential_sep: newline_list
rule 44 case_clause: Case WORD linebreak In linebreak case_list Esac
rule 45 case_clause: Case WORD linebreak In linebreak Esac
rule 46 case_list: case_item
rule 47 case_list: case_list case_item
rule 48 case_item: patterns ")" compound_list DSEMI linebreak
rule 49 case_item: patterns ")" linebreak DSEMI linebreak
rule 50 patterns: WORD
rule 51 patterns: patterns "|" WORD
rule 52 if_clause: If compound_list Then compound_list else_part Fi
rule 53 if_clause: If compound_list Then compound_list Fi
rule 54 else_part: Elif compound_list Then compound_list
rule 55 else_part: Elif compound_list Then compound_list else_part
rule 56 else_part: Else compound_list
rule 57 compound_list: linebreak term
rule 58 compound_list: linebreak term separator
rule 59 term: term separator and_or
rule 60 term: and_or
rule 61 separator: separator_op linebreak
rule 62 separator: newline_list
rule 63 simple_command: cmd_prefix cmd_word cmd_suffix
rule 64 simple_command: cmd_prefix cmd_word
rule 65 simple_command: cmd_prefix
rule 66 simple_command: cmd_name cmd_suffix
rule 67 simple_command: cmd_name
rule 68 cmd_name: WORD
rule 69 cmd_word: WORD
rule 70 cmd_prefix: io_redirect
rule 71 cmd_prefix: cmd_prefix io_redirect
rule 72 cmd_prefix: ASSIGNMENT_WORD
rule 73 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 74 cmd_suffix: io_redirect
rule 75 cmd_suffix: cmd_suffix io_redirect
rule 76 cmd_suffix: WORD
rule 77 cmd_suffix: cmd_suffix WORD
rule 78 io_redirect: io_file
rule 79 io_redirect: IO_NUMBER io_file
rule 80 io_redirect: io_here
rule 81 io_redirect: IO_NUMBER io_here
rule 82 io_here: DLESS WORD
rule 83 io_here: DLESSDASH WORD
rule 84 io_file: "<" filename
rule 85 io_file: ">" filename
rule 86 io_file: DGREAT filename
rule 87 io_file: LESSGREAT filename
rule 88 io_file: CLOBBER filename
rule 89 filename: WORD
rule 90 separator_op: "&"
rule 91 separator_op: ";"
rule 92 newline_list: NEWLINE
rule 93 newline_list: newline_list NEWLINE
rule 94 linebreak: newline_list
rule 95 linebreak: 

