

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 command: function_definition
rule 19 function_definition: WORD "(" ")" linebreak compound_command
rule 20 compound_command: brace_group
rule 21 compound_command: subshell
rule 22 compound_command: if_clause
rule 23 compound_command: while_clause
rule 24 compound_command: until_clause
rule 25 compound_command: for_clause
rule 26 compound_command: case_clause
rule 27 brace_group: Lbrace compound_list Rbrace
rule 28 subshell: "(" compound_list ")"
rule 29 while_clause: While compound_list do_group
rule 30 until_clause: Until compound_list do_group
rule 31 do_group: Do compound_list Done
rule 32 for_clause: For name do_group
rule 33 for_clause: For name sequential_sep do_group
rule 34 for_clause: For name linebreak In sequential_sep do_group
rule 35 for_clause: For name linebreak In wordlist sequential_sep do_group
rule 36 name: NAME
rule 37 wordlist: WORD
rule 38 wordlist: wordlist WORD
rule 39 sequential_sep: ";" linebreak
rule 40 sequential_sep: newline_list
rule 41 case_clause: Case WORD linebreak In linebreak case_list Esac
rule 42 case_clause: Case WORD linebreak In linebreak Esac
rule 43 case_list: case_item
rule 44 case_list: case_list case_item
rule 45 case_item: patterns ")" compound_list DSEMI linebreak
rule 46 case_item: patterns ")" linebreak DSEMI linebreak
rule 47 patterns: WORD
rule 48 patterns: patterns "|" WORD
rule 49 if_clause: If compound_list Then compound_list else_part Fi
rule 50 if_clause: If compound_list Then compound_list Fi
rule 51 else_part: Elif compound_list Then compound_list
rule 52 else_part: Elif compound_list Then compound_list else_part
rule 53 else_part: Else compound_list
rule 54 compound_list: linebreak term
rule 55 compound_list: linebreak term separator
rule 56 term: term separator and_or
rule 57 term: and_or
rule 58 separator: separator_op linebreak
rule 59 separator: newline_list
rule 60 simple_command: cmd_prefix cmd_word cmd_suffix
rule 61 simple_command: cmd_prefix cmd_word
rule 62 simple_command: cmd_prefix
rule 63 simple_command: cmd_name cmd_suffix
rule 64 simple_command: cmd_name
rule 65 cmd_name: WORD
rule 66 cmd_word: WORD
rule 67 cmd_prefix: io_redirect
rule 68 cmd_prefix: cmd_prefix io_redirect
rule 69 cmd_prefix: ASSIGNMENT_WORD
rule 70 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 71 cmd_suffix: io_redirect
rule 72 cmd_suffix: cmd_suffix io_redirect
rule 73 cmd_suffix: WORD
rule 74 cmd_suffix: cmd_suffix WORD
rule 75 io_redirect: io_file
rule 76 io_redirect: IO_NUMBER io_file
rule 77 io_file: "<" filename
rule 78 io_file: ">" filename
rule 79 io_file: DGREAT filename
rule 80 io_file: LESSGREAT filename
rule 81 io_file: CLOBBER filename
rule 82 filename: WORD
rule 83 separator_op: "&"
rule 84 separator_op: ";"
rule 85 newline_list: NEWLINE
rule 86 newline_list: newline_list NEWLINE
rule 87 linebreak: newline_list
rule 88 linebreak: 

