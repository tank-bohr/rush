

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 compound_command: brace_group
rule 19 compound_command: if_clause
rule 20 compound_command: while_clause
rule 21 compound_command: until_clause
rule 22 brace_group: Lbrace compound_list Rbrace
rule 23 while_clause: While compound_list do_group
rule 24 until_clause: Until compound_list do_group
rule 25 do_group: Do compound_list Done
rule 26 if_clause: If compound_list Then compound_list else_part Fi
rule 27 if_clause: If compound_list Then compound_list Fi
rule 28 else_part: Elif compound_list Then compound_list
rule 29 else_part: Elif compound_list Then compound_list else_part
rule 30 else_part: Else compound_list
rule 31 compound_list: linebreak term
rule 32 compound_list: linebreak term separator
rule 33 term: term separator and_or
rule 34 term: and_or
rule 35 separator: separator_op linebreak
rule 36 separator: newline_list
rule 37 simple_command: cmd_prefix cmd_word cmd_suffix
rule 38 simple_command: cmd_prefix cmd_word
rule 39 simple_command: cmd_prefix
rule 40 simple_command: cmd_name cmd_suffix
rule 41 simple_command: cmd_name
rule 42 cmd_name: WORD
rule 43 cmd_word: WORD
rule 44 cmd_prefix: io_redirect
rule 45 cmd_prefix: cmd_prefix io_redirect
rule 46 cmd_prefix: ASSIGNMENT_WORD
rule 47 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 48 cmd_suffix: io_redirect
rule 49 cmd_suffix: cmd_suffix io_redirect
rule 50 cmd_suffix: WORD
rule 51 cmd_suffix: cmd_suffix WORD
rule 52 io_redirect: io_file
rule 53 io_redirect: IO_NUMBER io_file
rule 54 io_file: "<" filename
rule 55 io_file: ">" filename
rule 56 io_file: DGREAT filename
rule 57 io_file: LESSGREAT filename
rule 58 io_file: CLOBBER filename
rule 59 filename: WORD
rule 60 separator_op: "&"
rule 61 separator_op: ";"
rule 62 newline_list: NEWLINE
rule 63 newline_list: newline_list NEWLINE
rule 64 linebreak: newline_list
rule 65 linebreak: 

