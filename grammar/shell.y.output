

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 command: function_definition
rule 19 function_definition: WORD "(" ")" linebreak compound_command
rule 20 compound_command: brace_group
rule 21 compound_command: if_clause
rule 22 compound_command: while_clause
rule 23 compound_command: until_clause
rule 24 compound_command: for_clause
rule 25 compound_command: case_clause
rule 26 brace_group: Lbrace compound_list Rbrace
rule 27 while_clause: While compound_list do_group
rule 28 until_clause: Until compound_list do_group
rule 29 do_group: Do compound_list Done
rule 30 for_clause: For name do_group
rule 31 for_clause: For name sequential_sep do_group
rule 32 for_clause: For name linebreak In sequential_sep do_group
rule 33 for_clause: For name linebreak In wordlist sequential_sep do_group
rule 34 name: NAME
rule 35 wordlist: WORD
rule 36 wordlist: wordlist WORD
rule 37 sequential_sep: ";" linebreak
rule 38 sequential_sep: newline_list
rule 39 case_clause: Case WORD linebreak In linebreak case_list Esac
rule 40 case_clause: Case WORD linebreak In linebreak Esac
rule 41 case_list: case_item
rule 42 case_list: case_list case_item
rule 43 case_item: patterns ")" compound_list DSEMI linebreak
rule 44 case_item: patterns ")" linebreak DSEMI linebreak
rule 45 patterns: WORD
rule 46 patterns: patterns "|" WORD
rule 47 if_clause: If compound_list Then compound_list else_part Fi
rule 48 if_clause: If compound_list Then compound_list Fi
rule 49 else_part: Elif compound_list Then compound_list
rule 50 else_part: Elif compound_list Then compound_list else_part
rule 51 else_part: Else compound_list
rule 52 compound_list: linebreak term
rule 53 compound_list: linebreak term separator
rule 54 term: term separator and_or
rule 55 term: and_or
rule 56 separator: separator_op linebreak
rule 57 separator: newline_list
rule 58 simple_command: cmd_prefix cmd_word cmd_suffix
rule 59 simple_command: cmd_prefix cmd_word
rule 60 simple_command: cmd_prefix
rule 61 simple_command: cmd_name cmd_suffix
rule 62 simple_command: cmd_name
rule 63 cmd_name: WORD
rule 64 cmd_word: WORD
rule 65 cmd_prefix: io_redirect
rule 66 cmd_prefix: cmd_prefix io_redirect
rule 67 cmd_prefix: ASSIGNMENT_WORD
rule 68 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 69 cmd_suffix: io_redirect
rule 70 cmd_suffix: cmd_suffix io_redirect
rule 71 cmd_suffix: WORD
rule 72 cmd_suffix: cmd_suffix WORD
rule 73 io_redirect: io_file
rule 74 io_redirect: IO_NUMBER io_file
rule 75 io_file: "<" filename
rule 76 io_file: ">" filename
rule 77 io_file: DGREAT filename
rule 78 io_file: LESSGREAT filename
rule 79 io_file: CLOBBER filename
rule 80 filename: WORD
rule 81 separator_op: "&"
rule 82 separator_op: ";"
rule 83 newline_list: NEWLINE
rule 84 newline_list: newline_list NEWLINE
rule 85 linebreak: newline_list
rule 86 linebreak: 

