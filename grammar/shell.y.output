  DGREAT        shift, and go to state 23
  LESSGREAT     shift, and go to state 24
  CLOBBER       shift, and go to state 25
  "<"           shift, and go to state 21
  ">"           shift, and go to state 22
  $default      reduce using rule 1 (program)

  complete_commands  go to state 6
  complete_command  go to state 7
  list          go to state 8
  and_or        go to state 9
  pipeline      go to state 10
  pipe_sequence  go to state 11
  command       go to state 12
  simple_command  go to state 13
  cmd_prefix    go to state 14
  cmd_name      go to state 15
  io_redirect   go to state 17
  io_file       go to state 19

