

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 compound_command: brace_group
rule 19 compound_command: if_clause
rule 20 brace_group: Lbrace compound_list Rbrace
rule 21 if_clause: If compound_list Then compound_list else_part Fi
rule 22 if_clause: If compound_list Then compound_list Fi
rule 23 else_part: Elif compound_list Then compound_list
rule 24 else_part: Elif compound_list Then compound_list else_part
rule 25 else_part: Else compound_list
rule 26 compound_list: linebreak term
rule 27 compound_list: linebreak term separator
rule 28 term: term separator and_or
rule 29 term: and_or
rule 30 separator: separator_op linebreak
rule 31 separator: newline_list
rule 32 simple_command: cmd_prefix cmd_word cmd_suffix
rule 33 simple_command: cmd_prefix cmd_word
rule 34 simple_command: cmd_prefix
rule 35 simple_command: cmd_name cmd_suffix
rule 36 simple_command: cmd_name
rule 37 cmd_name: WORD
rule 38 cmd_word: WORD
rule 39 cmd_prefix: io_redirect
rule 40 cmd_prefix: cmd_prefix io_redirect
rule 41 cmd_prefix: ASSIGNMENT_WORD
rule 42 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 43 cmd_suffix: io_redirect
rule 44 cmd_suffix: cmd_suffix io_redirect
rule 45 cmd_suffix: WORD
rule 46 cmd_suffix: cmd_suffix WORD
rule 47 io_redirect: io_file
rule 48 io_redirect: IO_NUMBER io_file
rule 49 io_file: "<" filename
rule 50 io_file: ">" filename
rule 51 io_file: DGREAT filename
rule 52 io_file: LESSGREAT filename
rule 53 io_file: CLOBBER filename
rule 54 filename: WORD
rule 55 separator_op: "&"
rule 56 separator_op: ";"
rule 57 newline_list: NEWLINE
rule 58 newline_list: newline_list NEWLINE
rule 59 linebreak: newline_list
rule 60 linebreak: 

