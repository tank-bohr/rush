

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 compound_command: brace_group
rule 19 compound_command: if_clause
rule 20 compound_command: while_clause
rule 21 compound_command: until_clause
rule 22 compound_command: for_clause
rule 23 compound_command: case_clause
rule 24 brace_group: Lbrace compound_list Rbrace
rule 25 while_clause: While compound_list do_group
rule 26 until_clause: Until compound_list do_group
rule 27 do_group: Do compound_list Done
rule 28 for_clause: For name do_group
rule 29 for_clause: For name sequential_sep do_group
rule 30 for_clause: For name linebreak In sequential_sep do_group
rule 31 for_clause: For name linebreak In wordlist sequential_sep do_group
rule 32 name: NAME
rule 33 wordlist: WORD
rule 34 wordlist: wordlist WORD
rule 35 sequential_sep: ";" linebreak
rule 36 sequential_sep: newline_list
rule 37 case_clause: Case WORD linebreak In linebreak case_list Esac
rule 38 case_clause: Case WORD linebreak In linebreak Esac
rule 39 case_list: case_item
rule 40 case_list: case_list case_item
rule 41 case_item: patterns ")" compound_list DSEMI linebreak
rule 42 case_item: patterns ")" linebreak DSEMI linebreak
rule 43 patterns: WORD
rule 44 patterns: patterns "|" WORD
rule 45 if_clause: If compound_list Then compound_list else_part Fi
rule 46 if_clause: If compound_list Then compound_list Fi
rule 47 else_part: Elif compound_list Then compound_list
rule 48 else_part: Elif compound_list Then compound_list else_part
rule 49 else_part: Else compound_list
rule 50 compound_list: linebreak term
rule 51 compound_list: linebreak term separator
rule 52 term: term separator and_or
rule 53 term: and_or
rule 54 separator: separator_op linebreak
rule 55 separator: newline_list
rule 56 simple_command: cmd_prefix cmd_word cmd_suffix
rule 57 simple_command: cmd_prefix cmd_word
rule 58 simple_command: cmd_prefix
rule 59 simple_command: cmd_name cmd_suffix
rule 60 simple_command: cmd_name
rule 61 cmd_name: WORD
rule 62 cmd_word: WORD
rule 63 cmd_prefix: io_redirect
rule 64 cmd_prefix: cmd_prefix io_redirect
rule 65 cmd_prefix: ASSIGNMENT_WORD
rule 66 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 67 cmd_suffix: io_redirect
rule 68 cmd_suffix: cmd_suffix io_redirect
rule 69 cmd_suffix: WORD
rule 70 cmd_suffix: cmd_suffix WORD
rule 71 io_redirect: io_file
rule 72 io_redirect: IO_NUMBER io_file
rule 73 io_file: "<" filename
rule 74 io_file: ">" filename
rule 75 io_file: DGREAT filename
rule 76 io_file: LESSGREAT filename
rule 77 io_file: CLOBBER filename
rule 78 filename: WORD
rule 79 separator_op: "&"
rule 80 separator_op: ";"
rule 81 newline_list: NEWLINE
rule 82 newline_list: newline_list NEWLINE
rule 83 linebreak: newline_list
rule 84 linebreak: 

