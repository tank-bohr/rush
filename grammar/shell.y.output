

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipeline: Bang pipe_sequence
rule 14 pipe_sequence: command
rule 15 pipe_sequence: pipe_sequence "|" linebreak command
rule 16 command: simple_command
rule 17 command: compound_command
rule 18 compound_command: brace_group
rule 19 compound_command: if_clause
rule 20 compound_command: while_clause
rule 21 compound_command: until_clause
rule 22 compound_command: for_clause
rule 23 brace_group: Lbrace compound_list Rbrace
rule 24 while_clause: While compound_list do_group
rule 25 until_clause: Until compound_list do_group
rule 26 do_group: Do compound_list Done
rule 27 for_clause: For name do_group
rule 28 for_clause: For name sequential_sep do_group
rule 29 for_clause: For name linebreak In sequential_sep do_group
rule 30 for_clause: For name linebreak In wordlist sequential_sep do_group
rule 31 name: NAME
rule 32 wordlist: WORD
rule 33 wordlist: wordlist WORD
rule 34 sequential_sep: ";" linebreak
rule 35 sequential_sep: newline_list
rule 36 if_clause: If compound_list Then compound_list else_part Fi
rule 37 if_clause: If compound_list Then compound_list Fi
rule 38 else_part: Elif compound_list Then compound_list
rule 39 else_part: Elif compound_list Then compound_list else_part
rule 40 else_part: Else compound_list
rule 41 compound_list: linebreak term
rule 42 compound_list: linebreak term separator
rule 43 term: term separator and_or
rule 44 term: and_or
rule 45 separator: separator_op linebreak
rule 46 separator: newline_list
rule 47 simple_command: cmd_prefix cmd_word cmd_suffix
rule 48 simple_command: cmd_prefix cmd_word
rule 49 simple_command: cmd_prefix
rule 50 simple_command: cmd_name cmd_suffix
rule 51 simple_command: cmd_name
rule 52 cmd_name: WORD
rule 53 cmd_word: WORD
rule 54 cmd_prefix: io_redirect
rule 55 cmd_prefix: cmd_prefix io_redirect
rule 56 cmd_prefix: ASSIGNMENT_WORD
rule 57 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 58 cmd_suffix: io_redirect
rule 59 cmd_suffix: cmd_suffix io_redirect
rule 60 cmd_suffix: WORD
rule 61 cmd_suffix: cmd_suffix WORD
rule 62 io_redirect: io_file
rule 63 io_redirect: IO_NUMBER io_file
rule 64 io_file: "<" filename
rule 65 io_file: ">" filename
rule 66 io_file: DGREAT filename
rule 67 io_file: LESSGREAT filename
rule 68 io_file: CLOBBER filename
rule 69 filename: WORD
rule 70 separator_op: "&"
rule 71 separator_op: ";"
rule 72 newline_list: NEWLINE
rule 73 newline_list: newline_list NEWLINE
rule 74 linebreak: newline_list
rule 75 linebreak: 

