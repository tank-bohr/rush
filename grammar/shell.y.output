

-------- Grammar --------

rule 1 program: linebreak
rule 2 program: linebreak complete_commands linebreak
rule 3 complete_commands: complete_command
rule 4 complete_commands: complete_commands newline_list complete_command
rule 5 complete_command: list separator_op
rule 6 complete_command: list
rule 7 list: list separator_op and_or
rule 8 list: and_or
rule 9 and_or: pipeline
rule 10 and_or: and_or AND_IF linebreak pipeline
rule 11 and_or: and_or OR_IF linebreak pipeline
rule 12 pipeline: pipe_sequence
rule 13 pipe_sequence: command
rule 14 command: simple_command
rule 15 simple_command: cmd_prefix cmd_word cmd_suffix
rule 16 simple_command: cmd_prefix cmd_word
rule 17 simple_command: cmd_prefix
rule 18 simple_command: cmd_name cmd_suffix
rule 19 simple_command: cmd_name
rule 20 cmd_name: WORD
rule 21 cmd_word: WORD
rule 22 cmd_prefix: io_redirect
rule 23 cmd_prefix: cmd_prefix io_redirect
rule 24 cmd_prefix: ASSIGNMENT_WORD
rule 25 cmd_prefix: cmd_prefix ASSIGNMENT_WORD
rule 26 cmd_suffix: io_redirect
rule 27 cmd_suffix: cmd_suffix io_redirect
rule 28 cmd_suffix: WORD
rule 29 cmd_suffix: cmd_suffix WORD
rule 30 io_redirect: io_file
rule 31 io_redirect: IO_NUMBER io_file
rule 32 io_file: "<" filename
rule 33 io_file: ">" filename
rule 34 io_file: DGREAT filename
rule 35 io_file: LESSGREAT filename
rule 36 io_file: CLOBBER filename
rule 37 filename: WORD
rule 38 separator_op: "&"
rule 39 separator_op: ";"
rule 40 newline_list: NEWLINE
rule 41 newline_list: newline_list NEWLINE
rule 42 linebreak: newline_list
rule 43 linebreak: 

------- Symbols -------

