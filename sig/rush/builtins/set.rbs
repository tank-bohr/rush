module Rush
  module Builtins
    # `set [-/+ options] [--] [arg ...]` — toggle shell options (-x/+x and the
    # `-o name`/`+o name` long form) and, when operands follow (or after `--`),
    # replace the positional parameters. With no operands the parameters are left
    # unchanged; an unknown option is ignored. Options: -e/errexit, -u/nounset,
    # -x/xtrace, -f/noglob, -v/verbose.
    class Set < Base
      extend T::Sig

      OPTIONS: { "e" => :errexit, "u" => :nounset, "x" => :xtrace, "f" => :noglob, "v" => :verbose }

      LONG: { "errexit" => :errexit, "nounset" => :nounset, "xtrace" => :xtrace, "noglob" => :noglob, "verbose" => :verbose }

      def call: () -> Status

      private

      def strip_options: (Array[String] args) -> Array[String]?

      def consume_options: (Array[String] args) -> Integer

      def advance: (Array[String] args, Integer index) -> Integer

      def positionals: (Array[String] args, Integer index) -> Array[String]?

      def option?: (String? flag) -> bool

      def apply: (String flag) -> void

      def apply_long: (String? sign, String? name) -> Integer

      def toggle: (Symbol? option, String? sign) -> void
    end
  end
end
