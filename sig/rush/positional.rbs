module Rush
  # The positional parameters $1..$n: a list of strings that `set` replaces,
  # `shift` drops the front of, and a function call brackets with #with so the
  # caller's are restored on return. Reads ($1, $#, $@, the for-loop word list)
  # delegate to the underlying array.
  class Positional
    @values: Array[String]

    extend Forwardable

    # def_delegators :@values — reads delegated to the underlying array.
    def ==: (untyped other) -> bool
    def []: (Integer index) -> String?
    def size: () -> Integer
    def empty?: () -> bool
    def join: (?String? separator) -> String
    def map: [U] () { (String value) -> U } -> Array[U]
           | () -> ::Enumerator[String, ::Array[untyped]]
    def each: () { (String value) -> void } -> Array[String]
    def to_a: () -> Array[String]

    def initialize: (?Array[String] values) -> void

    def replace: (Array[String] values) -> void

    def shift: (Integer count) -> void

    def with: [T] (Array[String] values) { () -> T } -> T
  end
end
