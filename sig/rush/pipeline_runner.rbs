module Rush
  # Runs a multi-stage pipeline: a pipe between each pair of stages, every stage
  # forked, the parent's pipe ends closed, then waitpid for all. The pipeline's
  # status is the last stage's.
  class PipelineRunner
    @executor: Executor

    @commands: untyped

    # One stage: position + the shared pipe array + the stage count. Its methods
    # live in a reopened class (see the .rb) so Steep can type them; pipes stay
    # untyped (raw IO.pipe pairs).
    class Stage < ::Data
      attr_reader index: Integer
      attr_reader pipes: untyped
      attr_reader count: Integer

      def self.new: (Integer index, untyped pipes, Integer count) -> Stage

      def last?: () -> bool

      def input: () -> untyped

      def output: () -> untyped

      def ends: () -> Array[untyped]

      # Layer this stage's pipe ends over the base IoTable.
      def io: (IoTable base) -> IoTable
    end

    def initialize: (Executor executor, untyped commands) -> void

    def call: () -> Status

    private

    def build_pipes: () -> untyped

    def start_stage: (Stage stage) -> untyped

    def run_stage: (Stage stage) -> Status

    def close_unused: (Stage stage) -> void

    def close_all: (untyped pipes) -> void

    def wait: (untyped pids) -> Status
  end
end
