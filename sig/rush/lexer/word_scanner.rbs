module Rush
  class Lexer
    # Scans one word from the shared StringScanner into an AST::Word of typed
    # segments: literal runs (quote-removed, with a `quoted` flag) and :param
    # segments for $name / ${...}. Handles the three quoting forms; command
    # substitution and arithmetic arrive in later slices.
    class WordScanner
      extend T::Sig

      @scanner: StringScanner

      @terminator: Regexp?

      @segments: Array[untyped]

      @literal: String

      TERMINATOR: Regexp

      LITERAL_RUN: Regexp

      WHOLE_LITERAL: Regexp

      DOUBLE_LITERAL: Regexp

      DOUBLE_SPECIAL: Array[String]

      DISPATCH: Hash[String, Symbol]

      def self.next_word: (StringScanner scanner) -> AST::Word

      def self.entire: (String text) -> AST::Word

      def initialize: (StringScanner scanner, ?terminator: Regexp?) -> void

      def scan: () -> AST::Word

      private

      def ended?: () -> bool

      def step: () -> void

      def literal_pattern: () -> Regexp

      def single_quote: () -> void

      def double_quote: () -> void

      def end_double?: () -> bool

      def double_step: () -> void

      def double_escape: () -> void

      def dollar: () -> void

      def double_dollar: () -> void

      def backtick: () -> void

      def escape: () -> void

      def push: (untyped value, quoted: bool) -> void

      def add: (untyped segment) -> void

      def flush: () -> void
    end
  end
end
