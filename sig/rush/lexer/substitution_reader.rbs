module Rush
  class Lexer
    # Reads the raw body of a command substitution from the shared scanner:
    # $( ... ) with balanced parentheses, or ` ... ` up to the next backtick.
    # The body is re-parsed and executed at expansion time.
    class SubstitutionReader
      extend T::Sig

      @scanner: StringScanner

      @depth: Integer

      DEPTH_DELTA: Hash[String, Integer]

      def initialize: (StringScanner scanner) -> void

      def parens: () -> String

      def backticks: () -> String?

      # Read the body of $(( ... )) after the leading `((`, up to the matching
      # `))`, allowing balanced inner parentheses.
      def arithmetic: () -> String

      private

      def collect: (String body) -> String

      def arith_char: () -> String?

      def arith_close: () -> String?

      def paren_char: () -> String

      def adjust: (String char) -> void
    end
  end
end
