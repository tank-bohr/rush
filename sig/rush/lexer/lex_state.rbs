module Rush
  class Lexer
    # Tracks command position (POSIX Grammar Rule 1) plus the for-header and case
    # modes (Rules 4-6): the for NAME and `in`, and the case subject / `in` /
    # pattern / `esac` positions. Modes are a single token (not a stack), so
    # `for`/`case` nested *directly* inside a case body are not tracked.
    class LexState
      extend T::Sig

      @command_position: bool

      @expect_filename: bool

      @mode: Symbol

      REDIRECT_OPS: Array[String | Symbol]

      INTRODUCERS: Array[String | Symbol]

      NEUTRAL: Array[Symbol]

      TRANSITIONS: Hash[Array[Symbol | String], Symbol]

      def initialize: () -> void

      def expects_command?: () -> bool

      # A command word here is a real command name, so alias substitution applies:
      # the normal mode and a case arm's command list. The for-header and case
      # subject/pattern modes do not expand aliases, even when a newline resets
      # command position.
      def command_mode?: () -> bool

      def for_name?: () -> bool

      def for_in?: () -> bool

      def case_subject?: () -> bool

      def case_in?: () -> bool

      def case_arm?: () -> bool

      def case_pat?: () -> bool

      def advance: (untyped symbol) -> void

      private

      def reset: () -> void

      def consume_word: () -> void
    end
  end
end
