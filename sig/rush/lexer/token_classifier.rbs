module Rush
  class Lexer
    # Classifies a scanned word given the lexer state: a reserved word (only an
    # unquoted single-literal word in command position), an ASSIGNMENT_WORD (an
    # unquoted NAME= prefix), or a plain WORD. The assignment value keeps its
    # quoted segments (x="a b").
    class TokenClassifier
      extend T::Sig

      @word: AST::Word

      @state: LexState

      NAME: Regexp

      RESERVED: Hash[String, Symbol]

      FOR_IN: Hash[String, Symbol]

      def initialize: (AST::Word word, LexState state) -> void

      def call: () -> [ Symbol, untyped ]

      private

      def state_token: () -> [ Symbol, untyped ]?

      def forced: () -> [ Symbol, untyped ]?

      def header_token: () -> [ Symbol, untyped ]?

      def arm_token: () -> Symbol

      def classify: () -> [ Symbol, untyped ]

      def for_header: () -> Symbol?

      def reserved: () -> Symbol?

      def assignment_name: () -> String?

      def capture: (untyped value) -> String?

      def assignment_token: (String name) -> [ Symbol, untyped ]

      def assignment_value: (String name) -> untyped
    end
  end
end
