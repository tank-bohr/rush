module Rush
  class SystemCalls
    # File-test queries for the test/[ builtin (-e -f -d -r -w -x -s -h/-L), mixed
    # into SystemCalls. Thin File delegations, like the rest of the syscall port.
    module FileTests
      extend T::Sig

      def exist?: (String path) -> bool

      def file?: (String path) -> bool

      def directory?: (String path) -> bool

      def readable?: (String path) -> bool

      def writable?: (String path) -> bool

      def executable?: (String path) -> bool

      def file_nonempty?: (String path) -> bool

      def symlink?: (String path) -> bool
    end
  end
end
