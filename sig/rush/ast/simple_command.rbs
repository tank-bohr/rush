module Rush
  module AST
    # `name=val ... cmd arg ... >file` — variable assignments, argv words and
    # redirections (in source order within each group).
    class SimpleCommand < Node
      @assignments: Array[Assignment]

      @words: Array[Word]

      @redirects: Array[Redirect]

      attr_reader assignments: Array[Assignment]

      attr_reader words: Array[Word]

      attr_reader redirects: Array[Redirect]

      def initialize: (Array[Assignment] assignments, Array[Word] words, Array[Redirect] redirects) -> void

      def execute: (Executor executor) -> Status
    end
  end
end
