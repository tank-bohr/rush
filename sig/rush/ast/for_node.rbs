module Rush
  module AST
    # `for name [in words]; do body; done`. With an explicit word list the words
    # are expanded (and field-split); with no `in` clause the loop iterates over
    # the positional parameters ($@).
    class For < Node
      @name: String

      @words: Array[Word]?

      @body: Node

      attr_reader name: String

      attr_reader words: Array[Word]?

      attr_reader body: Node

      def initialize: (String name, Array[Word]? words, Node body) -> void

      def execute: (Executor executor) -> Status

      private

      def values: (Executor executor) -> Array[String]
    end
  end
end
