module Rush
  module AST
    # `if cond; then body; [elif/else ...] fi`. Runs the condition list; on
    # success runs the consequent, otherwise the alternative (an else List, a
    # nested If for elif, or nil). With no matching branch the status is 0.
    class If < Node
      extend T::Sig

      @condition: Node

      @consequent: Node

      @alternative: Node?

      attr_reader condition: Node

      attr_reader consequent: Node

      attr_reader alternative: Node?

      def initialize: (Node condition, Node consequent, Node? alternative) -> void

      def execute: (Executor executor) -> Status
    end
  end
end
