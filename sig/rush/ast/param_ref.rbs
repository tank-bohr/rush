module Rush
  module AST
    PARAM_BRACED: ::Regexp

    # A parameter reference parsed from $name or ${...}. The operator word is
    # expanded lazily at expansion time. (Data.define; members kept untyped — the
    # AST is still being typed.)
    class ParamRef < ::Data
      attr_reader name: untyped
      attr_reader op: untyped
      attr_reader arg: untyped

      def self.new: (name: untyped, op: untyped, arg: untyped) -> ParamRef

      def self.simple: (untyped name) -> ParamRef

      def self.parse: (untyped body) -> ParamRef

      def self.length?: (untyped body) -> bool
    end
  end
end
