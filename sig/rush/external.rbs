module Rush
  # Runs an external program through the system port with the command's env and
  # IoTable, translating the result: the OS exit/signal status, or POSIX 127
  # (not found) / 126 (not executable).
  class External
    @executor: Executor

    @argv: Array[String]

    @io: IoTable

    @env: Hash[String, String]

    def initialize: (Executor executor, Array[String] argv, IoTable io, Hash[String, String] env) -> void

    def call: () -> Status

    private

    def system: () -> SystemCalls

    # close_others closes inherited fds >= 3 (e.g. pipeline pipe ends) in the child.
    def spawn_options: () -> Hash[Integer | Symbol, untyped]

    def error_status: (SystemCallError error) -> Status
  end
end
