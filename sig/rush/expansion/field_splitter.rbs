module Rush
  module Expansion
    # Entry point for IFS field splitting: it hands the parts and the IFS
    # delimiter sets (an Ifs value) to IfsScanner, which applies the three POSIX
    # cases.
    class FieldSplitter
      extend T::Sig

      @ifs: Ifs

      def initialize: (String? ifs) -> void

      def split: (Array[[ String, bool, bool ]] parts) -> Array[String]
    end
  end
end
