module Rush
  module Expansion
    # Implements ${p#pat} ${p##pat} ${p%pat} ${p%%pat}: remove from the value the
    # smallest (#/%) or largest (##/%%) prefix (#) or suffix (%) that matches the
    # glob pattern, leaving the value unchanged when nothing matches.
    class PatternRemoval
      @system: SystemCalls

      @op: String

      @value: String

      @pattern: String

      def initialize: (SystemCalls system, String op, String value, String pattern) -> void

      def call: () -> String

      private

      def strip_prefix: () -> String

      def strip_suffix: () -> String

      def prefixes: () -> Array[String]

      def suffixes: () -> Array[String]

      def order: (Array[String] list) -> Array[String]

      def match?: (String part) -> bool
    end
  end
end
