module Rush
  module Expansion
    module Arithmetic
      # A Pratt (precedence-climbing) parser turning the tokens into the AST.
      # Binary precedence is table-driven; the conditional operator (?:) binds
      # loosest and is right-associative. Malformed input or leftover tokens
      # raise a syntax error (matching dash's "expecting primary"/"expecting EOF").
      class Parser
        @tokens: Array[[ Symbol, String ]]

        @pos: Integer

        PRECEDENCE: Hash[String, Integer]

        UNARY: Array[String]

        ASSIGN: Array[String]

        def initialize: (Array[[ Symbol, String ]] tokens) -> void

        def parse: () -> node

        private

        # Assignment binds loosest and is right-associative; its target must be a
        # bare name (an lvalue), so e.g. `5 = 3` is a syntax error.
        def assignment: () -> node

        def conditional: () -> node

        def binary: (Integer min) -> node

        def fold: (node left) -> node

        def combine: (String op, node left, node right) -> node

        def unary: () -> node

        def primary: () -> node

        def grouped: () -> node

        # The next token's text, or nil past the end (so the precedence loop and the
        # accept?/lookahead helpers stop cleanly at EOF).
        def peek: () -> String?

        def advance: () -> String

        def take: () -> [ Symbol, String ]

        def accept?: (String token) -> bool

        def expect: (String token) -> void

        def oops: () -> bot
      end
    end
  end
end
