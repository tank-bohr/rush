module Rush
  module Expansion
    module Arithmetic
      # Pure 64-bit integer arithmetic for $(( )): two's-complement wrapping (so
      # overflow matches dash), C-style truncated-toward-zero division/modulo,
      # and the unary/binary operator tables the evaluator dispatches through.
      # Comparison and logical results are 1 or 0. Never uses Kernel#eval.
      module Number
        LIMIT: untyped

        # Parse an integer constant (decimal, 0-octal or 0x-hex, optional sign and
        # surrounding blanks), as both literals and variable values are read.
        def self?.parse: (untyped text) -> untyped

        def self?.unary: (untyped op, untyped value) -> untyped

        def self?.binary: (untyped op, untyped left, untyped right) -> untyped

        def self?.wrap: (untyped num) -> untyped

        def self?.bool: (untyped flag) -> (1 | 0)

        def self?.divide: (untyped left, untyped right) -> untyped

        def self?.modulo: (untyped left, untyped right) -> untyped

        UNARY: { "+" => untyped, "-" => untyped, "!" => untyped, "~" => untyped }

        BINARY: { "+" => untyped, "-" => untyped, "*" => untyped, "/" => untyped, "%" => untyped, "<<" => untyped, ">>" => untyped, "&" => untyped, "|" => untyped, "^" => untyped, "<" => untyped, "<=" => untyped, ">" => untyped, ">=" => untyped, "==" => untyped, "!=" => untyped }
      end
    end
  end
end
