module Rush
  module Expansion
    module Arithmetic
      # The arithmetic AST. Declared as real Data classes; #result lives in a
      # reopened class (see the .rb) so Steep attributes it to the node. Node
      # members and the inter-node results stay untyped (the AST holds AST; Number
      # is still untyped), ctx is the Evaluator.
      class Num < ::Data
        attr_reader value: untyped
        def self.new: (untyped value) -> Num
        def result: (Evaluator ctx) -> untyped
      end

      class Var < ::Data
        attr_reader name: untyped
        def self.new: (untyped name) -> Var
        def result: (Evaluator ctx) -> untyped
      end

      class Unary < ::Data
        attr_reader op: untyped
        attr_reader operand: untyped
        def self.new: (untyped op, untyped operand) -> Unary
        def result: (Evaluator ctx) -> untyped
      end

      class Binary < ::Data
        attr_reader op: untyped
        attr_reader left: untyped
        attr_reader right: untyped
        def self.new: (untyped op, untyped left, untyped right) -> Binary
        def result: (Evaluator ctx) -> untyped
      end

      class And < ::Data
        attr_reader left: untyped
        attr_reader right: untyped
        def self.new: (untyped left, untyped right) -> And
        def result: (Evaluator ctx) -> untyped
      end

      class Or < ::Data
        attr_reader left: untyped
        attr_reader right: untyped
        def self.new: (untyped left, untyped right) -> Or
        def result: (Evaluator ctx) -> untyped
      end

      class Cond < ::Data
        attr_reader test: untyped
        attr_reader truthy: untyped
        attr_reader falsy: untyped
        def self.new: (untyped test, untyped truthy, untyped falsy) -> Cond
        def result: (Evaluator ctx) -> untyped
      end

      class Assign < ::Data
        attr_reader name: untyped
        attr_reader op: untyped
        attr_reader rhs: untyped
        def self.new: (untyped name, untyped op, untyped rhs) -> Assign
        def result: (Evaluator ctx) -> untyped
      end
    end
  end
end
