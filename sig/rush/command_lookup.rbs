module Rush
  # Resolves a command name for `type` and `command -v`: a reserved word, a
  # function, a special or regular builtin, or an executable file found by
  # searching PATH (or used directly when the name contains a slash). #find runs
  # an ordered list of resolvers and returns the first Match (Unknown if none).
  class CommandLookup
    @executor: untyped

    KEYWORDS: ::Array["!" | "{" | "}" | "case" | "do" | "done" | "elif" | "else" | "esac" | "fi" | "for" | "if" | "in" | "then" | "until" | "while"]

    SPECIAL: ::Array[":" | "." | "break" | "continue" | "eval" | "exec" | "exit" | "export" | "readonly" | "return" | "set" | "shift" | "times" | "trap" | "unset"]

    RESOLVERS: ::Array[:as_keyword | :as_alias | :as_function | :as_special | :as_builtin | :as_file]

    # A resolved lookup result: it is "known", and subclasses render the line
    # `type` (#describe) and `command -v` (#terse) print. Only an executable
    # caches its own location; the others leave the cache untouched.
    class Match
      @name: untyped

      @detail: untyped

      def initialize: (untyped name, ?untyped? detail) -> void

      def known?: () -> true

      def cache_into: (untyped _cache) -> nil

      private

      attr_reader name: untyped

      attr_reader detail: untyped
    end

    # An unresolved name: not known, and nothing to describe.
    class Unknown < Match
      def known?: () -> false

      def describe: () -> nil
    end

    # A keyword / function / special / regular builtin, named by a fixed label.
    class Labelled < Match
      def describe: () -> ::String

      def terse: () -> untyped
    end

    # A shell alias; `command -v` prints its definition.
    class Aliased < Match
      def describe: () -> ::String

      def terse: () -> ::String
    end

    # An external executable found on PATH (or used directly via a slash path).
    class Executable < Match
      def describe: () -> ::String

      def terse: () -> untyped

      def cache_into: (untyped cache) -> untyped
    end

    def initialize: (untyped executor) -> void

    # The Match for a name (Unknown if it resolves to nothing). An alias outranks
    # a function/builtin but not a reserved word; a PATH/slash file is the last
    # resort.
    def find: (untyped name) -> untyped

    # The `type`/`command -V` description line for a name, or nil if unknown.
    def describe: (untyped name) -> untyped

    private

    def as_keyword: (untyped name) -> untyped

    def as_alias: (untyped name) -> untyped

    def as_function: (untyped name) -> untyped

    def as_special: (untyped name) -> untyped

    def as_builtin: (untyped name) -> untyped

    def as_file: (untyped name) -> untyped

    def aliases: () -> untyped

    def functions: () -> untyped

    def path_of: (untyped name) -> (nil | untyped)

    def join: (untyped dir, untyped name) -> (untyped | ::String)

    def executable?: (untyped path) -> untyped

    def dirs: () -> untyped
  end
end
