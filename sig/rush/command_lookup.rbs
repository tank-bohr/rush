module Rush
  # Resolves a command name for `type` and `command -v`: a reserved word, a
  # function, a special or regular builtin, or an executable file found by
  # searching PATH (or used directly when the name contains a slash). #find runs
  # an ordered list of resolvers and returns the first Match (Unknown if none).
  class CommandLookup
    @executor: untyped

    KEYWORDS: Array[String]

    SPECIAL: Array[String]

    RESOLVERS: Array[Symbol]

    # A resolved lookup result: it is "known", and subclasses render the line
    # `type` (#describe) and `command -v` (#terse) print. Only an executable
    # caches its own location; the others leave the cache untouched.
    class Match
      @name: String

      @detail: String?

      def initialize: (String name, ?String? detail) -> void

      def known?: () -> bool

      # describe/terse form the Match protocol that #find's result is used through.
      # Unknown leaves terse unimplemented — it is only called after a #known?
      # guard, never on an Unknown (Steep can't narrow the union by #known?).
      def describe: () -> String?

      def terse: () -> String?

      def cache_into: (untyped cache) -> void

      private

      attr_reader name: String

      attr_reader detail: String?
    end

    # An unresolved name: not known, and nothing to describe.
    class Unknown < Match
      def known?: () -> bool

      def describe: () -> nil
    end

    # A keyword / function / special / regular builtin, named by a fixed label.
    class Labelled < Match
      def describe: () -> String

      def terse: () -> String
    end

    # A shell alias; `command -v` prints its definition.
    class Aliased < Match
      def describe: () -> String

      def terse: () -> String
    end

    # An external executable found on PATH (or used directly via a slash path).
    class Executable < Match
      def describe: () -> String

      # detail (the resolved path) is String? on the base Match, so terse is too.
      def terse: () -> String?

      def cache_into: (untyped cache) -> void
    end

    def initialize: (untyped executor) -> void

    # The Match for a name (Unknown if it resolves to nothing). An alias outranks
    # a function/builtin but not a reserved word; a PATH/slash file is the last
    # resort.
    def find: (String name) -> Match

    # The `type`/`command -V` description line for a name, or nil if unknown.
    def describe: (String name) -> String?

    private

    def as_keyword: (String name) -> untyped

    def as_alias: (String name) -> untyped

    def as_function: (String name) -> untyped

    def as_special: (String name) -> untyped

    def as_builtin: (String name) -> untyped

    def as_file: (String name) -> untyped

    def aliases: () -> untyped

    def functions: () -> untyped

    def path_of: (String name) -> untyped

    def join: (String dir, String name) -> String

    def executable?: (String path) -> untyped

    def dirs: () -> untyped
  end
end
