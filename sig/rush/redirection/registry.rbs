module Rush
  # I/O redirection: the per-kind appliers and the registry that dispatches to them.
  module Redirection
    # O(1) redirection-kind -> applier lookup, populated by default_registry.
    class Registry
      @appliers: Hash[Symbol, untyped]

      def initialize: () -> void

      def register: (Symbol kind, untyped applier) -> void

      def fetch: (Symbol kind) -> untyped
    end

    # <> opens read-write and creates the file (POSIX), unlike the string modes.
    DEFAULTS: Hash[Symbol, Array[untyped]]

    # Default fd for the dup operators: 1 for >&, 0 for <&.
    DUPS: Hash[Symbol, Integer]

    def self.default_registry: () -> Registry
  end
end
